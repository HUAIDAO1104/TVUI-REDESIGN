<?xml version="1.0" encoding="utf-8"?>
<!-- 播放器小功能按钮 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_sm" />
            <solid android:color="@color/glass_white_focus" />
            <stroke
                android:width="@dimen/focus_border"
                android:color="@color/focus_border" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_sm" />
            <solid android:color="#3314141E" />
            <stroke
                android:width="1dp"
                android:color="@color/stroke_glass" />
        </shape>
    </item>
</selector>
