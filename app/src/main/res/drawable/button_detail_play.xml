<?xml version="1.0" encoding="utf-8"?>
<!-- 详情页播放按钮 — 品牌橙主操作 (mm单位已修复) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/radius_pill" />
            <solid android:color="@color/brand_primary" />
            <stroke android:width="@dimen/focus_border" android:color="@color/focus_border" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/radius_pill" />
            <solid android:color="@color/brand_primary_dark" />
        </shape>
    </item>
</selector>
