<?xml version="1.0" encoding="utf-8"?>
<!-- 直播频道行 — 焦点白玻璃 / 选中橙描边 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/radius_md" />
            <solid android:color="@color/glass_white_focus" />
            <stroke android:width="@dimen/focus_border" android:color="@color/focus_border" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <corners android:radius="@dimen/radius_md" />
            <solid android:color="@color/selected_bg" />
            <stroke android:width="1dp" android:color="@color/selected_border" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/radius_md" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
