<?xml version="1.0" encoding="utf-8"?>
<!--
    历史记录页面 — Netflix × tvOS 毛玻璃风格
    顶部：大标题 + 操作图标（毛玻璃圆钮）
    内容：海报卡片网格（TV 安全边距 48dp）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical">

    <!-- ── 顶部标题栏 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/tv_safe_margin_h"
        android:paddingTop="@dimen/tv_safe_margin_v"
        android:paddingRight="@dimen/tv_safe_margin_h"
        android:paddingBottom="@dimen/spacing_16">

        <View
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/spacing_12"
            android:background="@drawable/shape_source_flag_line" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="历史记录"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_2xl"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvDelTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/spacing_12"
            android:background="@drawable/bg_badge_dark"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:paddingLeft="@dimen/spacing_12"
            android:paddingTop="@dimen/spacing_4"
            android:paddingRight="@dimen/spacing_12"
            android:paddingBottom="@dimen/spacing_4"
            android:text="确定键删除当前选中记录"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_sm"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/tvDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_8"
            android:background="@drawable/button_dialog_vod"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:padding="@dimen/spacing_8"
            android:src="@drawable/icon_delete"
            android:stateListAnimator="@animator/focus_scale" />

        <ImageView
            android:id="@+id/tvClear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_8"
            android:background="@drawable/button_dialog_vod"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:padding="@dimen/spacing_8"
            android:src="@drawable/icon_clear"
            android:stateListAnimator="@animator/focus_scale" />
    </LinearLayout>

    <!-- ── 海报网格 ── -->
    <com.owen.tvrecyclerview.widget.TvRecyclerView
        android:id="@+id/mGridView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="@dimen/tv_safe_margin_h"
        android:paddingTop="@dimen/spacing_8"
        android:paddingRight="@dimen/tv_safe_margin_h"
        android:paddingBottom="@dimen/spacing_24"
        app:tv_horizontalSpacingWithMargins="@dimen/spacing_12"
        app:tv_selectedItemIsCentered="true"
        app:tv_verticalSpacingWithMargins="@dimen/spacing_12" />
</LinearLayout>
