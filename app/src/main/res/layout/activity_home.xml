<?xml version="1.0" encoding="utf-8"?>
<!--
    首页布局 — Netflix × Material Design 毛玻璃风格
    结构：
      ┌─────────────────────────────────────────────────┐
      │  全屏壁纸背景层（模糊/渐变蒙版）                    │
      │  ┌───────────────────────────────────────────┐  │
      │  │  顶部导航栏（App Logo + 名称 + 时间）  52dp  │  │
      │  ├───────────────────────────────────────────┤  │
      │  │  分类 Tab 行（横向 TvRecyclerView）  48dp   │  │
      │  │  Tab 指示线  3dp                           │  │
      │  ├───────────────────────────────────────────┤  │
      │  │  内容 ViewPager（卡片网格）                  │  │
      │  └───────────────────────────────────────────┘  │
      └─────────────────────────────────────────────────┘
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ── 层1：全屏壁纸背景 ── -->
    <ImageView
        android:id="@+id/bgWallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        android:visibility="gone" />

    <!-- ── 层2：顶部到底部渐变蒙版（增强内容可读性）── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hero_gradient"
        android:visibility="gone" />

    <!-- ── 层3：主内容层 ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ┌── 顶部导航栏 ──┐ -->
        <LinearLayout
            android:id="@+id/topLayout"
            android:layout_width="0dp"
            android:layout_height="@dimen/top_bar_height"
            android:layout_marginTop="@dimen/tv_safe_margin_v"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/tv_safe_margin_h"
            android:paddingRight="@dimen/tv_safe_margin_h"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- App 名称（品牌标识） -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:gravity="left|center_vertical"
                android:letterSpacing="0.05"
                android:text="@string/app_name"
                android:textAlignment="gravity"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_hero"
                android:textStyle="bold"
                android:shadowColor="@color/overlay_heavy"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6" />

            <!-- 弹性空间 -->
            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- 时间显示（右对齐，略小字号）-->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:gravity="right|center_vertical"
                android:textAlignment="gravity"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_lg" />

        </LinearLayout>

        <!-- ┌── 分类 Tab 行 ──┐ -->
        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/mGridView"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/spacing_4"
            android:paddingLeft="@dimen/tv_safe_margin_h"
            android:paddingRight="@dimen/tv_safe_margin_h"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/topLayout"
            app:tv_selectedItemIsCentered="false" />

        <!-- Tab 底部指示线 -->
        <View
            android:id="@+id/tabDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mGridView" />

        <!-- ┌── 内容区 ViewPager ──┐ -->
        <com.github.tvbox.osc.ui.tv.widget.NoScrollViewPager
            android:id="@+id/mViewPager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tabDivider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
