<?xml version="1.0" encoding="utf-8"?>
<!--
    推送页面 — tvOS 毛玻璃风格
    居中玻璃卡片：白底二维码 + 地址 + 推送按钮
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel"
        android:elevation="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_32">

        <!-- 白底二维码卡片（保证可扫描） -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_dialog_rounded"
            android:padding="@dimen/spacing_10">

            <ImageView
                android:id="@+id/ivQRCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_20"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:textAlignment="gravity"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_md"
            tools:text="扫码或浏览器访问 http://192.168.1.100:9978 推送视频" />

        <TextView
            android:id="@+id/pushLocal"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_md"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_20"
            android:background="@drawable/btn_brand_primary"
            android:focusable="true"
            android:gravity="center"
            android:paddingLeft="@dimen/spacing_24"
            android:paddingRight="@dimen/spacing_24"
            android:stateListAnimator="@animator/focus_scale"
            android:text="推送剪贴板内容"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
