<?xml version="1.0" encoding="utf-8"?>
<!--
    搜索页 — 毛玻璃三栏布局
    比例：[键盘区 30%] | [热词/历史 15%] | [搜索结果 55%]
    ┌──────────────┬──────────┬───────────────────────────┐
    │  指定搜索源   │ 热词|历史 │                           │
    │  ┌─搜索框─┐  │ ───────  │      搜索结果网格           │
    │  └────────┘  │ 词条列表  │                           │
    │  [搜索][清空] │          │                           │
    │  虚拟键盘     │          │                           │
    └──────────────┴──────────┴───────────────────────────┘
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="horizontal">

    <!-- ── 左栏：搜索控制区（30%）── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:background="@drawable/bg_glass_sidebar"
        android:layout_margin="@dimen/spacing_12"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <!-- 指定搜索源按钮 -->
        <TextView
            android:id="@+id/tvSearchCheckboxBtn"
            style="@style/Widget.TVBox.GlassButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height_md"
            android:layout_marginBottom="@dimen/spacing_10"
            android:text="指定搜索源"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md" />

        <!-- 搜索输入框（毛玻璃背景） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_input_height"
            android:layout_marginBottom="@dimen/spacing_10"
            android:background="@drawable/bg_glass_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/spacing_10"
            android:paddingRight="@dimen/spacing_10">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:layout_marginEnd="@dimen/spacing_8"
                android:alpha="0.6"
                android:src="@drawable/icon_search" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="搜索影视..."
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_md" />

        </LinearLayout>

        <!-- 搜索/清空按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height_md"
            android:layout_marginBottom="@dimen/spacing_12"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSearch"
                style="@style/Widget.TVBox.PrimaryButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="搜索"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md" />

            <Space
                android:layout_width="@dimen/spacing_8"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvClear"
                style="@style/Widget.TVBox.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="清空"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md" />

        </LinearLayout>

        <!-- 虚拟键盘 -->
        <com.github.tvbox.osc.ui.tv.widget.SearchKeyboard
            android:id="@+id/keyBoardRoot"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 二维码/远程输入区 -->
        <LinearLayout
            android:id="@+id/remoteRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_20"
                android:gravity="center_horizontal"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md" />

            <ImageView
                android:id="@+id/ivQRCode"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_16" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── 中栏：热词/历史词条（15%）── -->
    <LinearLayout
        android:id="@+id/llWord"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:background="@drawable/bg_glass_sidebar"
        android:layout_marginTop="@dimen/spacing_12"
        android:layout_marginBottom="@dimen/spacing_12"
        android:layout_marginRight="@dimen/spacing_12"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_12"
        android:paddingBottom="@dimen/spacing_12">

        <!-- 热词/历史切换按钮 -->
        <TextView
            android:id="@+id/wordSwitch"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height_md"
            android:layout_marginLeft="@dimen/spacing_8"
            android:layout_marginRight="@dimen/spacing_8"
            android:layout_marginBottom="@dimen/spacing_8"
            android:background="@drawable/btn_glass_normal"
            android:focusable="true"
            android:gravity="center"
            android:text="热词 | 历史"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_sm" />

        <!-- 词条列表 -->
        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/mGridViewWord"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="@dimen/spacing_8"
            android:paddingRight="@dimen/spacing_8"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:tv_horizontalSpacingWithMargins="@dimen/spacing_6"
            app:tv_selectedItemIsCentered="true"
            app:tv_verticalSpacingWithMargins="@dimen/spacing_6" />

    </LinearLayout>

    <!-- ── 右栏：搜索结果（55%）── -->
    <LinearLayout
        android:id="@+id/llLayout"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5.5"
        android:layout_marginTop="@dimen/spacing_12"
        android:layout_marginBottom="@dimen/spacing_12"
        android:layout_marginRight="@dimen/spacing_12"
        android:orientation="vertical"
        android:padding="@dimen/spacing_4">

        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/mGridView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="invisible"
            app:tv_horizontalSpacingWithMargins="@dimen/spacing_8"
            app:tv_selectedItemIsCentered="true"
            app:tv_verticalSpacingWithMargins="@dimen/spacing_8" />

    </LinearLayout>

</LinearLayout>
