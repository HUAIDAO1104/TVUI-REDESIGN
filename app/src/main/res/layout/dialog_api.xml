<?xml version="1.0" encoding="utf-8"?>
<!--
    配置地址对话框 — tvOS 毛玻璃风格
    左侧：白底二维码卡片（扫码可读性）
    右侧：地址信息 + 操作按钮 + 点播/直播输入区
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_28">

        <!-- 二维码：白底卡片确保可扫描 -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_dialog_rounded"
            android:padding="@dimen/spacing_8">

            <ImageView
                android:id="@+id/ivQRCode"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:focusable="false" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_24"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_4"
            android:paddingBottom="@dimen/spacing_4">

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                tools:text="手机/电脑扫码或浏览器访问 http://192.168.1.100:9978 配置" />

            <!-- 配置历史与存储权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_12"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/apiHistory"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_sm"
                    android:layout_marginEnd="@dimen/spacing_6"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="历史配置"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/storagePermission"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_sm"
                    android:layout_marginStart="@dimen/spacing_6"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="存储权限"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <!-- 点播输入区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_10"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingEnd="@dimen/spacing_8"
                    android:text="点播"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_sm"
                    tools:ignore="RtlSymmetry,TextViewEdits" />

                <EditText
                    android:id="@+id/input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/input_dialog_api_input"
                    android:hint="请输入配置地址"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingLeft="@dimen/spacing_12"
                    android:paddingTop="@dimen/spacing_8"
                    android:paddingRight="@dimen/spacing_12"
                    android:paddingBottom="@dimen/spacing_8"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/inputSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/btn_height_sm"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:background="@drawable/btn_brand_primary"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/spacing_16"
                    android:paddingRight="@dimen/spacing_16"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="确定"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 直播输入区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingEnd="@dimen/spacing_8"
                    android:text="直播"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_sm"
                    tools:ignore="RtlSymmetry,TextViewEdits" />

                <EditText
                    android:id="@+id/inputLive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/input_dialog_api_input"
                    android:hint="请输入直播地址"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingLeft="@dimen/spacing_12"
                    android:paddingTop="@dimen/spacing_8"
                    android:paddingRight="@dimen/spacing_12"
                    android:paddingBottom="@dimen/spacing_8"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/inputSubmitLive"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/btn_height_sm"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:background="@drawable/btn_brand_primary"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/spacing_16"
                    android:paddingRight="@dimen/spacing_16"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="确定"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
