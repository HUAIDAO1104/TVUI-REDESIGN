<?xml version="1.0" encoding="utf-8"?>
<!--
    确认对话框 — tvOS 毛玻璃风格
    居中玻璃卡片 + 大标题 + 双胶囊按钮（焦点缩放动画）
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/spacing_32"
        android:paddingTop="@dimen/spacing_28"
        android:paddingRight="@dimen/spacing_32"
        android:paddingBottom="@dimen/spacing_24">

        <TextView
            android:id="@+id/confirmation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_24"
            android:gravity="center"
            android:singleLine="true"
            android:text="确定全部删除 ?"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_md"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/spacing_8"
                android:layout_weight="1"
                android:background="@drawable/btn_brand_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:stateListAnimator="@animator/focus_scale"
                android:text="是"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_md"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/spacing_8"
                android:layout_weight="1"
                android:background="@drawable/button_dialog_main"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:stateListAnimator="@animator/focus_scale"
                android:text="否"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md" />
        </TableRow>
    </LinearLayout>
</FrameLayout>
