<?xml version="1.0" encoding="utf-8"?>
<!-- 直播频道密码输入对话框 — 毛玻璃暗色卡片 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_24">

        <!-- 密码输入框 -->
        <EditText
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:background="@drawable/input_dialog_api_input"
            android:hint="请输入密码"
            android:inputType="textPassword"
            android:maxLines="1"
            android:paddingLeft="@dimen/spacing_12"
            android:paddingTop="@dimen/spacing_8"
            android:paddingRight="@dimen/spacing_12"
            android:paddingBottom="@dimen/spacing_8"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/text_md" />

        <!-- 确定按钮 -->
        <TextView
            android:id="@+id/inputSubmit"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_sm"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/spacing_8"
            android:background="@drawable/btn_brand_primary"
            android:focusable="true"
            android:gravity="center"
            android:paddingLeft="@dimen/spacing_16"
            android:paddingRight="@dimen/spacing_16"
            android:stateListAnimator="@animator/focus_scale"
            android:text="确定"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
