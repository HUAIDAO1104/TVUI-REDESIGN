<?xml version="1.0" encoding="utf-8"?>
<!--
    字幕设置对话框 — tvOS 毛玻璃风格
    分组排版：来源选择 / 字号 / 样式 / 延时，间距分区代替分隔线
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="480dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="@dimen/spacing_28">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <!-- ── 字幕来源 ── -->
            <TextView
                android:id="@+id/selectInternal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_md"
                android:layout_gravity="center"
                android:background="@drawable/button_dialog_main"
                android:focusable="true"
                android:gravity="center"
                android:stateListAnimator="@animator/focus_scale"
                android:text="选择内置字幕"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:visibility="gone" />

            <TextView
                android:id="@+id/selectLocal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_md"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_8"
                android:background="@drawable/button_dialog_main"
                android:focusable="true"
                android:gravity="center"
                android:stateListAnimator="@animator/focus_scale"
                android:text="选择本地字幕"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md" />

            <TextView
                android:id="@+id/selectRemote"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_md"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_8"
                android:background="@drawable/button_dialog_main"
                android:focusable="true"
                android:gravity="center"
                android:stateListAnimator="@animator/focus_scale"
                android:text="在线搜索字幕"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md" />

            <!-- ── 字号调节 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_20"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/subtitleSizeMinus"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字号减小"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/subtitleSizeText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="16"
                    android:textColor="@color/text_brand"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleSizePlus"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字号增大"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <!-- ── 字幕样式 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_12"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/subtitleStyleOne"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字幕样式一"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="" />

                <TextView
                    android:id="@+id/subtitleStyleTwo"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字幕样式二"
                    android:textColor="@color/color_FFB6C1"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── 延时说明 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_16"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="字幕延时仅对外挂字幕有效"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>

            <!-- ── 延时调节 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_8"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/subtitleTimeMinus"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字幕提前"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/subtitleTimeText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/text_brand"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleTimePlus"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height_md"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:gravity="center"
                    android:stateListAnimator="@animator/focus_scale"
                    android:text="字幕推迟"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
