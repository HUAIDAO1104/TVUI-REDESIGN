<?xml version="1.0" encoding="utf-8"?>
<!-- XWalk 组件下载对话框 — 毛玻璃暗色卡片 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_dialog_bg_main"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="@dimen/spacing_28">

        <TextView
            android:id="@+id/downXWalkArch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:focusable="false"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="下载XWalkView运行组件"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/downXWalk"
            android:layout_width="200dp"
            android:layout_height="@dimen/btn_height_md"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_24"
            android:background="@drawable/btn_brand_primary"
            android:focusable="true"
            android:gravity="center"
            android:stateListAnimator="@animator/focus_scale"
            android:text="下载"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold" />

    </LinearLayout>
</FrameLayout>
