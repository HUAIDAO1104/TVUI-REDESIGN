<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/shape_user_focus"
    android:stateListAnimator="@animator/focus_scale_subtle"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height_lg"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="@dimen/btn_height_lg"
            android:layout_height="match_parent"
            android:padding="@dimen/spacing_4"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/tvName"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:ellipsize="marquee"
            android:gravity="center_vertical"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingLeft="@dimen/spacing_12"
            android:paddingRight="@dimen/spacing_8"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md" />

        <TextView
            android:id="@+id/tvNote"
            android:layout_weight="4"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:ellipsize="marquee"
            android:gravity="end|center_vertical"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingLeft="@dimen/spacing_8"
            android:paddingRight="@dimen/spacing_12"
            android:singleLine="true"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_sm" />
    </LinearLayout>
</FrameLayout>
