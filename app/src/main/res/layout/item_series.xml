<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_margin="@dimen/spacing_4"
    android:background="@drawable/shape_source_series_focus"
    android:stateListAnimator="@animator/focus_scale_subtle"
    android:focusable="true">

    <TextView
        android:id="@+id/tvSeries"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height_md"
        android:ellipsize="marquee"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:paddingLeft="@dimen/spacing_8"
        android:paddingRight="@dimen/spacing_8"
        android:singleLine="true"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md" />
</LinearLayout>
