<?xml version="1.0" encoding="utf-8"?>
<!--
    VOD 播放器控制层 — 毛玻璃风格分层控制栏
    布局结构（由下往上）：
      ───────────────────────────────────────────────────
        进度条行：[时间] ══════SeekBar══════ [总时长]
        第一行按钮（常用）：上一集 下一集 重播 刷新 速度 比例 屏显
        第二行按钮（高级）：[解析源] 播放器 解码 字幕 音轨 片头 片尾 重置 横竖屏
      ───────────────────────────────────────────────────
    整体使用毛玻璃背景，左右按钮各占屏幕两侧
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── 顶部信息行（视频名 + 技术参数）── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/tv_safe_margin_h"
        android:paddingRight="@dimen/tv_safe_margin_h"
        android:paddingTop="@dimen/spacing_12">

        <LinearLayout
            android:id="@+id/tv_top_l_container"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:tag="tv_top_container"
            android:visibility="gone"
            tools:visibility="visible"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_info_name1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/http"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tv_videosize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:tag="vod_video_size"
                android:text="@string/_1024_x_768"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tv_top_r_container"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:tag="tv_top_container"
            android:visibility="gone"
            tools:visibility="visible"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/tv_screen_display"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/net_play_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingEnd="@dimen/spacing_10"
                    android:tag="vod_control_pause_time"
                    android:text="0Gbs"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tv_seek_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingEnd="@dimen/spacing_10"
                    android:tag="vod_control_pause_time"
                    android:text="@string/_00_00_00_00"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tv_sys_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:tag="vod_control_pause_time"
                    android:text="@string/_00_00_00"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_play_load_net_speed_right_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:ellipsize="end"
                android:maxLines="1"
                android:tag="vod_control_pause_time"
                android:text="@string/_0kb_s"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>
    </LinearLayout>

    <!-- ── 字幕层 ── -->
    <com.github.tvbox.osc.subtitle.widget.SimpleSubtitleView
        android:id="@+id/subtitle_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="@dimen/player_ctrl_height"
        android:gravity="center"
        android:paddingLeft="@dimen/tv_safe_margin_h"
        android:paddingRight="@dimen/tv_safe_margin_h"
        android:paddingBottom="@dimen/spacing_8"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- ── 毛玻璃控制栏（底部固定）── -->
    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginLeft="@dimen/tv_safe_margin_h"
        android:layout_marginRight="@dimen/tv_safe_margin_h"
        android:layout_marginBottom="@dimen/spacing_16"
        android:background="@drawable/bg_glass_player"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingLeft="@dimen/spacing_20"
        android:paddingRight="@dimen/spacing_20"
        android:paddingTop="@dimen/spacing_12"
        android:paddingBottom="@dimen/spacing_12"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- 第一行：常用功能按钮 -->
        <LinearLayout
            android:id="@+id/play_btn_group_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:orientation="horizontal"
            android:gravity="start">

            <!-- 「播放」标签 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_12"
                android:gravity="center_vertical"
                android:text="播放"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_sm"
                android:singleLine="true" />

            <TextView
                android:id="@+id/play_next"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="下一集" />

            <TextView
                android:id="@+id/play_pre"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="上一集" />

            <TextView
                android:id="@+id/play_retry"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="重播" />

            <TextView
                android:id="@+id/play_refresh"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="刷新" />

            <TextView
                android:id="@+id/play_speed"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="x1.0" />

            <TextView
                android:id="@+id/play_scale"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="16:9" />

            <TextView
                android:id="@+id/screen_display"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:text="屏显" />

        </LinearLayout>

        <!-- 第二行：高级选项 + 解析源 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:orientation="horizontal"
            android:gravity="start">

            <!-- 「高级」标签 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_12"
                android:gravity="center_vertical"
                android:text="高级"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_sm"
                android:singleLine="true" />

            <TextView
                android:id="@+id/play_player"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="播放器" />

            <TextView
                android:id="@+id/play_ijk"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="硬解码" />

            <TextView
                android:id="@+id/zimu_select"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="字幕" />

            <TextView
                android:id="@+id/audio_track_select"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="音轨"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:layout_marginStart="@dimen/spacing_12"
                android:gravity="center_vertical"
                android:text="片头尾"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_sm"
                android:id="@+id/play_time_start_end_text"
                android:singleLine="true" />

            <TextView
                android:id="@+id/play_time_start"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="01:00" />

            <TextView
                android:id="@+id/play_time_end"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="01:00" />

            <TextView
                android:id="@+id/play_time_reset"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_6"
                android:text="重置" />

            <TextView
                android:id="@+id/landscape_portrait"
                style="@style/Widget.TVBox.PlayerButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:text="横竖屏"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 解析源行（默认隐藏） -->
        <LinearLayout
            android:id="@+id/parse_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height_sm"
                android:layout_marginEnd="@dimen/spacing_12"
                android:gravity="center_vertical"
                android:text="解析"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_sm"
                android:singleLine="true" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/mGridParseView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_sm"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:tv_horizontalSpacingWithMargins="@dimen/spacing_6"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/spacing_6" />

        </LinearLayout>

        <!-- 进度条行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/curr_time"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:includeFontPadding="false"
                android:paddingEnd="@dimen/spacing_8"
                android:text="@string/_00_00"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="@dimen/spacing_20"
                android:layout_weight="1"
                android:background="@null"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:max="1000"
                android:maxHeight="@dimen/player_seekbar_height"
                android:minHeight="@dimen/player_seekbar_height"
                android:progressDrawable="@drawable/shape_player_control_vod_seek"
                android:thumb="@drawable/shape_player_control_vod_seek_thumb" />

            <TextView
                android:id="@+id/total_time"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:includeFontPadding="false"
                android:paddingStart="@dimen/spacing_8"
                android:text="@string/_00_00"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── 暂停状态居中提示 ── -->
    <FrameLayout
        android:id="@+id/tv_pause_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:tag="vod_control_pause"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|top"
            android:layout_marginStart="@dimen/tv_safe_margin_h"
            android:layout_marginTop="@dimen/spacing_16"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_info_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:paddingTop="@dimen/spacing_8"
                android:text="http://"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>

        <!-- 居中暂停图标 + 进度 -->
        <LinearLayout
            android:layout_width="@dimen/vs_280"
            android:layout_height="@dimen/vs_200"
            android:layout_gravity="center"
            android:background="@drawable/bg_glass_panel"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/icon_xl"
                android:layout_height="@dimen/icon_xl"
                android:layout_gravity="center"
                android:focusable="false"
                android:src="@drawable/icon_play" />

            <TextView
                android:id="@+id/tv_pause_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_16"
                android:focusable="false"
                android:tag="vod_control_pause_t"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_3xl"
                tools:text="01:23:45" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── 滑动进度提示 ── -->
    <TextView
        android:id="@+id/tv_slide_progress_text"
        android:layout_width="@dimen/vs_200"
        android:layout_height="@dimen/vs_100"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel"
        android:focusable="false"
        android:gravity="center"
        android:tag="vod_control_slide_info"
        android:textAlignment="gravity"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_3xl"
        android:visibility="gone"
        tools:text="→ 1:23" />

    <!-- ── 快进/退进度提示 ── -->
    <LinearLayout
        android:id="@+id/tv_progress_container"
        android:layout_width="@dimen/vs_280"
        android:layout_height="@dimen/vs_200"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel"
        android:focusable="false"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/tv_progress_icon"
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl"
            android:focusable="false"
            tools:src="@drawable/icon_back" />

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_16"
            android:focusable="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_3xl"
            tools:text="→ 1:23" />

    </LinearLayout>

    <!-- ── 加载动画 ── -->
    <ProgressBar
        android:layout_width="@dimen/loading_icon_size"
        android:layout_height="@dimen/loading_icon_size"
        android:layout_gravity="center"
        android:indeterminateBehavior="repeat"
        android:indeterminateDrawable="@drawable/anim_loading"
        android:indeterminateOnly="true"
        android:tag="vod_control_loading"
        android:visibility="gone" />

    <!-- 加载网速显示 -->
    <TextView
        android:id="@+id/tv_play_load_net_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/spacing_48"
        android:focusable="false"
        android:tag="play_load_net_speed"
        android:text="0"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_sm" />

    <!-- 返回按钮（左侧居中）-->
    <ImageView
        android:id="@+id/tv_back"
        android:layout_width="@dimen/icon_xl"
        android:layout_height="@dimen/icon_xl"
        android:layout_gravity="start|center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="@dimen/spacing_16"
        android:src="@drawable/icon_back"
        android:visibility="invisible" />

    <!-- 锁定按钮（右侧居中）-->
    <ImageView
        android:id="@+id/tv_lock"
        android:layout_width="@dimen/icon_xl"
        android:layout_height="@dimen/icon_xl"
        android:layout_gravity="end|center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="@dimen/spacing_16"
        android:src="@drawable/icon_unlock"
        android:visibility="invisible" />

    <!-- 3倍速提示 -->
    <FrameLayout
        android:id="@+id/play_speed_3_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel"
        android:padding="@dimen/spacing_12"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_speed_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.0 X"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold" />

    </FrameLayout>

</FrameLayout>
