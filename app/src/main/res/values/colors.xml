<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================================
         TVBox Netflix×Material Design 毛玻璃主题色彩系统
         设计基调：极深黑底 + 毛玻璃半透明层 + 白色文字 + 品牌橙高亮
    ============================================================ -->

    <!-- ── 背景层次 ── -->
    <!-- 最底层：纯黑屏幕背景 -->
    <color name="bg_screen">#0A0A0F</color>
    <!-- 内容面 -->
    <color name="bg_surface">#12121A</color>
    <!-- 略亮内容面 -->
    <color name="bg_surface_elevated">#1C1C28</color>
    <!-- 卡片背景 -->
    <color name="bg_card">#1E1E2E</color>

    <!-- ── 毛玻璃层（Glassmorphism）── -->
    <!-- 主毛玻璃：深色半透明，用于面板/控制栏 -->
    <color name="glass_dark">#CC0D0D18</color>
    <!-- 中等毛玻璃：用于卡片信息条/侧边栏 -->
    <color name="glass_medium">#B20D0D18</color>
    <!-- 浅毛玻璃：用于 Tooltip/提示层 -->
    <color name="glass_light">#801A1A2E</color>
    <!-- 亮色毛玻璃：白色系，用于聚焦高亮 -->
    <color name="glass_white">#20FFFFFF</color>
    <!-- 强白色毛玻璃：聚焦态背景 -->
    <color name="glass_white_focus">#30FFFFFF</color>
    <!-- 卡片底部渐变蒙版起始色（完全透明） -->
    <color name="glass_gradient_start">#00000000</color>
    <!-- 卡片底部渐变蒙版结束色 -->
    <color name="glass_gradient_end">#E6000000</color>
    <!-- 顶部 Hero 渐变蒙版结束色 -->
    <color name="glass_hero_overlay">#99000000</color>

    <!-- ── 品牌色 ── -->
    <!-- 主品牌色：Netflix 式橙红 -->
    <color name="brand_primary">#E50914</color>
    <!-- 品牌色深色态（聚焦/按下）-->
    <color name="brand_primary_dark">#B20710</color>
    <!-- 次要品牌色：信息蓝 -->
    <color name="brand_accent">#0CADE2</color>
    <!-- 次要品牌色深色态 -->
    <color name="brand_accent_dark">#0990BD</color>

    <!-- ── 文字颜色 ── -->
    <!-- 主文字：纯白 -->
    <color name="text_primary">#FFFFFFFF</color>
    <!-- 次要文字：略透明白 -->
    <color name="text_secondary">#CCF0F0F5</color>
    <!-- 三级文字 -->
    <color name="text_tertiary">#99CACAD5</color>
    <!-- 禁用/提示文字 -->
    <color name="text_hint">#66A0A0B0</color>
    <!-- 品牌橙文字（评分/徽章） -->
    <color name="text_brand">#E50914</color>
    <!-- 强调青蓝文字 -->
    <color name="text_accent">#0CADE2</color>
    <!-- 暖白：信息卡片标题 -->
    <color name="text_warm_white">#FFFFFAE0</color>

    <!-- ── 聚焦 / 选中状态 ── -->
    <!-- 焦点边框：纯白 -->
    <color name="focus_border">#FFFFFFFF</color>
    <!-- 焦点背景：白色毛玻璃 -->
    <color name="focus_bg">#28FFFFFF</color>
    <!-- 选中态背景：品牌橙半透明 -->
    <color name="selected_bg">#40E50914</color>
    <!-- 选中态边框 -->
    <color name="selected_border">#E50914</color>
    <!-- 激活态（Tab选中）-->
    <color name="active_indicator">#E50914</color>

    <!-- ── 分隔线 / 描边 ── -->
    <color name="divider">#1AFFFFFF</color>
    <color name="divider_strong">#33FFFFFF</color>
    <color name="stroke_glass">#26FFFFFF</color>

    <!-- ── 状态色 ── -->
    <color name="color_success">#00C853</color>
    <color name="color_warning">#FFB300</color>
    <color name="color_error">#FF1744</color>
    <color name="color_info">#0CADE2</color>
    <color name="color_live_badge">#FF1744</color>

    <!-- ── 叠加层 ── -->
    <color name="overlay_dim">#80000000</color>
    <color name="overlay_heavy">#CC000000</color>
    <color name="overlay_light">#40000000</color>
    <color name="overlay_scrim">#B3000000</color>

